<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=mscorlib">

    <s:String x:Key="IsThemeDictionary">Dark</s:String>

    <SolidColorBrush x:Key="AppBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="PanelBackground" Color="#2D2D30"/>
    <SolidColorBrush x:Key="PrimaryText" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="ControlBorder" Color="#434346"/>
    <SolidColorBrush x:Key="HeaderText" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PriceColor" Color="#FF8C00"/>
    
</ResourceDictionary>