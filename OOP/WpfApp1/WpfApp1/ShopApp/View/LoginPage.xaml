<Page x:Class="WpfApp1.ShopApp.View.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="{DynamicResource Authorization}">

    <Grid Background="{DynamicResource AppBackground}">

        <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource ControlBorder}" Width="300" Height="350" 
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Padding="20" CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Color="LightGray" ShadowDepth="2"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="{DynamicResource LoginTitle}" FontSize="24" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="{DynamicResource LabelLogin}" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="5" Margin="0,0,0,15" FontSize="14"/>

                <TextBlock Text="{DynamicResource LabelPassword}" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="5" Margin="0,0,0,15" FontSize="14"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" 
                           TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <Button Content="{DynamicResource BtnEnter}" Command="{Binding LoginCommand}" 
                        Style="{StaticResource MainButtonStyle}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="{DynamicResource BtnRegister}" Command="{Binding RegisterCommand}" 
                        Style="{StaticResource MainButtonStyle}" Margin="0, 13, 0, 0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>