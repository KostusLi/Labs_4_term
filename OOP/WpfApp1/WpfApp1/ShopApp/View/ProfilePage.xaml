<Page x:Class="WpfApp1.ShopApp.View.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="{DynamicResource BtnProfile}">

    <Grid Background="{DynamicResource AppBackground}">

        <Border Background="{DynamicResource PanelBackground}" 
                Width="400" Height="450" 
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Padding="30" CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.1" ShadowDepth="1"/>
            </Border.Effect>

            <StackPanel>
                <Button Command="{Binding GoBackCommand}" Content="{DynamicResource BtnBack}" 
                        HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" 
                        Foreground="{DynamicResource PrimaryText}" Cursor="Hand" Margin="0,0,0,10"/>

                <TextBlock Text="{DynamicResource BtnProfile}" FontSize="22" FontWeight="Bold" 
                           Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="{DynamicResource LabelNewLogin}" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,5"/>
                <TextBox Text="{Binding EditUsername, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="8" Margin="0,0,0,15" Background="{DynamicResource AppBackground}" 
                         Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource ControlBorder}"/>

                <TextBlock Text="{DynamicResource LabelNewPassword}" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,5"/>
                <TextBox Text="{Binding EditPassword, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="8" Margin="0,0,0,25" Background="{DynamicResource AppBackground}" 
                         Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource ControlBorder}"/>

                <Button Command="{Binding SaveProfileCommand}" Content="{DynamicResource BtnSave}" 
                        Style="{StaticResource MainButtonStyle}" Margin="0,0,0,30"/>

                <TextBlock Text="{DynamicResource LabelSettings}" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource LabelTheme}" Foreground="{DynamicResource SecondaryText}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Button Background="{DynamicResource PanelBackground}" Command="{Binding ChangeThemeCommand}" CommandParameter="Light" Content="{DynamicResource ThemeLight}" Margin="0,0,5,0" Padding="5"/>
                            <Button Background="{DynamicResource PanelBackground}" Command="{Binding ChangeThemeCommand}" CommandParameter="Dark" Content="{DynamicResource ThemeDark}" Padding="5"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{DynamicResource LabelLanguage}" Foreground="{DynamicResource SecondaryText}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Button Background="{DynamicResource PanelBackground}" Command="{Binding ChangeLangCommand}" CommandParameter="ru" Content="RU" Margin="0,0,5,0" Padding="5"/>
                            <Button Background="{DynamicResource PanelBackground}" Command="{Binding ChangeLangCommand}" CommandParameter="en" Content="EN" Padding="5"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </Border>
    </Grid>
</Page>