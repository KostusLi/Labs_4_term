<Window x:Class="WpfApp1.ShopApp.View.AddEditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Height="500" Width="400"
        Icon="/Resources/stalin.png"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="{DynamicResource PanelBackground}">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="{DynamicResource Name}" FontWeight="Bold"/>
            <TextBox Text="{Binding CurrentProduct.Title, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,5,0,15" Padding="5"/>

            <TextBlock Text="{DynamicResource Category}" FontWeight="Bold"/>
            <TextBox Text="{Binding CurrentProduct.Category, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,5,0,15" Padding="5"/>

            <TextBlock Text="{DynamicResource LabelDescription}" FontWeight="Bold"/>
            <TextBox Text="{Binding CurrentProduct.Description, UpdateSourceTrigger=PropertyChanged}" 
                     Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,15" Padding="5"/>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="{DynamicResource labelPrice}" FontWeight="Bold"/>
                    <TextBox Text="{Binding CurrentProduct.Price, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="{DynamicResource Sale}" FontWeight="Bold"/>
                    <TextBox Text="{Binding CurrentProduct.Discount, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="{DynamicResource LabelStock}" FontWeight="Bold"/>
            <TextBox Text="{Binding CurrentProduct.StockQuantity, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,5,0,20" Padding="5"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="{DynamicResource BtnSave}" Command="{Binding SaveCommand}" 
                        CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}}"
                        Style="{StaticResource MainButtonStyle}"/>

                <Button Grid.Column="1" Content="{DynamicResource BtnCancel}" Command="{Binding CancelCommand}" 
                        CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}}"
                        Background="{DynamicResource ControlBorder}" Padding="10" Margin="5,0,0,0"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>